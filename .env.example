# Privy (https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Solana RPC (Helius recommended — get one at helius.dev)
NEXT_PUBLIC_SOLANA_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Kamino REST API (no key needed, but pinning the base lets you swap to staging)
KAMINO_API_BASE=https://api.kamino.finance

# Jupiter (lite-api is free, pro requires key — lite is fine for MVP)
JUPITER_API_BASE=https://lite-api.jup.ag

# Filled in after running `npm run bootstrap`
NEXT_PUBLIC_XSTOCKS_MARKET_PUBKEY=
